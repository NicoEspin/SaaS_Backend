generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  FULFILLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  VOID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProductAttributeType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  ENUM
}

enum StockMovementType {
  PURCHASE_RECEIPT
  SALE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN
  INITIAL
}

model Tenant {
  id        String   @id @db.VarChar(26)
  slug      String   @unique @db.VarChar(64)
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships Membership[]
  branches    Branch[]

  products          Product[]
  productAttributeDefinitions ProductAttributeDefinition[]
  categories        Category[]
  customers         Customer[]
  orders            Order[]
  orderItems        OrderItem[]
  invoices          Invoice[]
  invoiceLines      InvoiceLine[]
  payments          Payment[]
  branchInventories BranchInventory[]
  stockMovements    StockMovement[]

  @@map("tenants")
}

model User {
  id           String   @id @db.VarChar(26)
  email        String   @unique @db.VarChar(320)
  fullName     String   @default("") @map("full_name") @db.VarChar(200)
  passwordHash String?  @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships Membership[]

  @@map("users")
}

model Membership {
  id        String         @id @db.VarChar(26)
  tenantId  String         @map("tenant_id") @db.VarChar(26)
  userId    String         @map("user_id") @db.VarChar(26)
  role      MembershipRole
  createdAt DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokens RefreshToken[]

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

model RefreshToken {
  id           String   @id @db.VarChar(26)
  membershipId String   @map("membership_id") @db.VarChar(26)
  tokenHash    String   @unique @map("token_hash") @db.Char(64)
  expiresAt    DateTime @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  lastUsedAt   DateTime? @map("last_used_at")
  createdAt    DateTime @default(now()) @map("created_at")

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Branch {
  id        String   @id @db.VarChar(26)
  tenantId  String   @map("tenant_id") @db.VarChar(26)
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  inventories BranchInventory[]
  orders      Order[]
  invoices    Invoice[]
  payments    Payment[]
  stockMovements StockMovement[]

  @@index([tenantId])
  @@map("branches")
}

model Product {
  id          String   @id @db.VarChar(26)
  tenantId    String   @map("tenant_id") @db.VarChar(26)
  categoryId  String?  @map("category_id") @db.VarChar(26)
  code        String   @db.VarChar(64)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  unit        String?  @db.VarChar(24)
  attributes  Json?    @db.JsonB
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventories  BranchInventory[]
  orderItems   OrderItem[]
  invoiceLines InvoiceLine[]
  stockMovements StockMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, code])
  @@index([tenantId, categoryId])
  @@map("products")
}

model Category {
  id        String   @id @db.VarChar(26)
  tenantId  String   @map("tenant_id") @db.VarChar(26)
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant                      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products                    Product[]
  productAttributeDefinitions ProductAttributeDefinition[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

model ProductAttributeDefinition {
  id               String               @id @db.VarChar(26)
  tenantId         String               @map("tenant_id") @db.VarChar(26)
  categoryId       String               @map("category_id") @db.VarChar(26)
  key              String               @db.VarChar(64)
  label            String               @db.VarChar(120)
  type             ProductAttributeType
  options          Json?                @db.JsonB
  unit             String?              @db.VarChar(24)
  isRequired       Boolean              @default(false) @map("is_required")
  isVisibleInTable Boolean              @default(false) @map("is_visible_in_table")
  sortOrder        Int                  @default(0) @map("sort_order")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([tenantId, categoryId, key])
  @@index([tenantId, categoryId])
  @@map("product_attribute_definitions")
}

model BranchInventory {
  id          String   @id @db.VarChar(26)
  tenantId    String   @map("tenant_id") @db.VarChar(26)
  branchId    String   @map("branch_id") @db.VarChar(26)
  productId   String   @map("product_id") @db.VarChar(26)
  price       Decimal? @db.Decimal(12, 2)
  cost        Decimal? @db.Decimal(12, 2)
  stockOnHand Int      @default(0) @map("stock_on_hand")
  minStock    Int      @default(0) @map("min_stock")
  maxStock    Int?     @map("max_stock")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, productId])
  @@index([tenantId, branchId])
  @@index([tenantId, productId])
  @@index([tenantId, branchId, stockOnHand])
  @@map("branch_inventories")
}

model Customer {
  id        String   @id @db.VarChar(26)
  tenantId  String   @map("tenant_id") @db.VarChar(26)
  // code is optional: @@unique allows multiple NULLs in Postgres
  code      String?  @db.VarChar(64)
  taxId     String?  @map("tax_id") @db.VarChar(32)
  name      String   @db.VarChar(200)
  email     String?  @db.VarChar(320)
  phone     String?  @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders   Order[]
  invoices Invoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, email])
  @@map("customers")
}

model Order {
  id            String      @id @db.VarChar(26)
  tenantId      String      @map("tenant_id") @db.VarChar(26)
  branchId      String      @map("branch_id") @db.VarChar(26)
  number        String      @db.VarChar(32)
  status        OrderStatus @default(DRAFT)
  customerId    String?     @map("customer_id") @db.VarChar(26)
  subtotal      Decimal     @default(0) @db.Decimal(12, 2)
  discountTotal Decimal     @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal      Decimal     @default(0) @map("tax_total") @db.Decimal(12, 2)
  total         Decimal     @default(0) @db.Decimal(12, 2)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  items    OrderItem[]
  invoices Invoice[]

  @@unique([tenantId, number])
  @@index([tenantId, createdAt])
  @@index([tenantId, branchId, createdAt])
  @@index([tenantId, branchId, status])
  @@index([tenantId, customerId])
  @@map("orders")
}

model OrderItem {
  id           String   @id @db.VarChar(26)
  tenantId     String   @map("tenant_id") @db.VarChar(26)
  orderId      String   @map("order_id") @db.VarChar(26)
  productId    String?  @map("product_id") @db.VarChar(26)
  nameSnapshot String   @map("name_snapshot") @db.VarChar(200)
  codeSnapshot String?  @map("code_snapshot") @db.VarChar(64)
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal    Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, orderId])
  @@index([productId])
  @@map("order_items")
}

model Invoice {
  id         String        @id @db.VarChar(26)
  tenantId   String        @map("tenant_id") @db.VarChar(26)
  branchId   String        @map("branch_id") @db.VarChar(26)
  orderId    String?       @map("order_id") @db.VarChar(26)
  customerId String?       @map("customer_id") @db.VarChar(26)
  number     String        @db.VarChar(32)
  status     InvoiceStatus @default(DRAFT)
  issuedAt   DateTime?     @map("issued_at")
  dueAt      DateTime?     @map("due_at")
  notes      String?       @db.Text
  customerNameSnapshot  String? @map("customer_name_snapshot") @db.VarChar(200)
  customerTaxIdSnapshot String? @map("customer_tax_id_snapshot") @db.VarChar(32)
  subtotal   Decimal       @default(0) @db.Decimal(12, 2)
  taxTotal   Decimal       @default(0) @map("tax_total") @db.Decimal(12, 2)
  total      Decimal       @default(0) @db.Decimal(12, 2)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  lines    InvoiceLine[]
  payments Payment[]

  @@unique([tenantId, number])
  @@index([tenantId, createdAt])
  @@index([tenantId, branchId, status])
  @@index([tenantId, customerId])
  @@map("invoices")
}

model InvoiceLine {
  id          String   @id @db.VarChar(26)
  tenantId    String   @map("tenant_id") @db.VarChar(26)
  invoiceId   String   @map("invoice_id") @db.VarChar(26)
  productId   String?  @map("product_id") @db.VarChar(26)
  description String   @db.VarChar(500)
  quantity    Int      @default(1)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal   Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, invoiceId])
  @@index([productId])
  @@map("invoice_lines")
}

model Payment {
  id        String        @id @db.VarChar(26)
  tenantId  String        @map("tenant_id") @db.VarChar(26)
  branchId  String        @map("branch_id") @db.VarChar(26)
  invoiceId String        @map("invoice_id") @db.VarChar(26)
  status    PaymentStatus @default(PENDING)
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  paidAt    DateTime?     @map("paid_at")
  reference String?       @db.VarChar(200)
  notes     String?       @db.Text
  createdAt DateTime      @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
  @@index([tenantId, branchId, paidAt])
  @@map("payments")
}

model StockMovement {
  id             String            @id @db.VarChar(26)
  tenantId       String            @map("tenant_id") @db.VarChar(26)
  branchId       String            @map("branch_id") @db.VarChar(26)
  productId      String            @map("product_id") @db.VarChar(26)
  type           StockMovementType
  quantity       Int
  quantityBefore Int               @map("quantity_before")
  quantityAfter  Int               @map("quantity_after")
  referenceId    String?           @map("reference_id") @db.VarChar(26)
  referenceType  String?           @map("reference_type") @db.VarChar(32)
  note           String?           @db.VarChar(500)
  createdBy      String?           @map("created_by") @db.VarChar(26)
  createdAt      DateTime          @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId, createdAt])
  @@index([tenantId, productId, createdAt])
  @@index([tenantId, referenceId])
  @@map("stock_movements")
}
