generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PAID
  CANCELLED
  FULFILLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  VOID
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum InvoiceMode {
  INTERNAL
  ARCA
}

enum InvoiceDocType {
  A
  B
}

enum InvoiceFiscalProvider {
  ARCA
}

enum InvoiceFiscalStatus {
  PENDING
  AUTHORIZED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  CANCELLED
  COMPLETED
}

enum PurchaseReceiptStatus {
  POSTED
  VOID
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ProductAttributeType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  ENUM
}

enum StockMovementType {
  PURCHASE_RECEIPT
  SALE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN
  INITIAL
}

enum CustomerType {
  RETAIL
  WHOLESALE
}

enum CustomerTaxIdType {
  CUIT
  CUIL
  DNI
  PASSPORT
  FOREIGN
}

enum CustomerVatCondition {
  REGISTERED
  MONOTAX
  EXEMPT
  FINAL_CONSUMER
  FOREIGN
}

model Tenant {
  id        String   @id @db.VarChar(26)
  slug      String   @unique @db.VarChar(64)
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships Membership[]
  branches    Branch[]

  products          Product[]
  productAttributeDefinitions ProductAttributeDefinition[]
  categories        Category[]
  customers         Customer[]
  orders            Order[]
  orderItems        OrderItem[]
  invoices          Invoice[]
  invoiceLines      InvoiceLine[]
  invoiceFiscals    InvoiceFiscal[]
  invoiceSequences  InvoiceSequence[]
  billingProfile    TenantBillingProfile?
  branchFiscalSettings BranchFiscalSettings[]
  payments          Payment[]
  branchInventories BranchInventory[]
  stockMovements    StockMovement[]

  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  purchaseReceipts   PurchaseReceipt[]
  purchaseReceiptItems PurchaseReceiptItem[]

  @@map("tenants")
}

model User {
  id           String   @id @db.VarChar(26)
  email        String   @unique @db.VarChar(320)
  fullName     String   @default("") @map("full_name") @db.VarChar(200)
  passwordHash String?  @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships Membership[]
  stockMovementsCreated StockMovement[] @relation("StockMovementCreatedBy")

  @@map("users")
}

model Membership {
  id        String         @id @db.VarChar(26)
  tenantId  String         @map("tenant_id") @db.VarChar(26)
  userId    String         @map("user_id") @db.VarChar(26)
  role      MembershipRole
  activeBranchId String?   @map("active_branch_id") @db.VarChar(26)
  createdAt DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeBranch Branch? @relation("MembershipActiveBranch", fields: [activeBranchId], references: [id], onDelete: SetNull)

  refreshTokens RefreshToken[]

  createdOrders Order[] @relation("OrderCreatedByMembership")

  createdPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreatedByMembership")
  createdPurchaseReceipts PurchaseReceipt[] @relation("PurchaseReceiptCreatedByMembership")

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("memberships")
}

model RefreshToken {
  id           String   @id @db.VarChar(26)
  membershipId String   @map("membership_id") @db.VarChar(26)
  tokenHash    String   @unique @map("token_hash") @db.Char(64)
  expiresAt    DateTime @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  lastUsedAt   DateTime? @map("last_used_at")
  createdAt    DateTime @default(now()) @map("created_at")

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Branch {
  id        String   @id @db.VarChar(26)
  tenantId  String   @map("tenant_id") @db.VarChar(26)
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  activeForMemberships Membership[] @relation("MembershipActiveBranch")

  inventories BranchInventory[]
  orders      Order[]
  invoices    Invoice[]
  purchaseOrders  PurchaseOrder[]
  purchaseReceipts PurchaseReceipt[]
  fiscalSettings BranchFiscalSettings?
  invoiceSequences InvoiceSequence[]
  payments    Payment[]
  stockMovements StockMovement[]

  @@index([tenantId])
  @@map("branches")
}

model Product {
  id          String   @id @db.VarChar(26)
  tenantId    String   @map("tenant_id") @db.VarChar(26)
  categoryId  String?  @map("category_id") @db.VarChar(26)
  code        String   @db.VarChar(64)
  name        String   @db.VarChar(200)
  description String?  @db.Text
  unit        String?  @db.VarChar(24)
  attributes  Json?    @db.JsonB
  vatRate     Decimal  @default(0.21) @map("vat_rate") @db.Decimal(6, 4)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventories  BranchInventory[]
  orderItems   OrderItem[]
  invoiceLines InvoiceLine[]
  stockMovements StockMovement[]

  purchaseOrderItems PurchaseOrderItem[]
  purchaseReceiptItems PurchaseReceiptItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, code])
  @@index([tenantId, categoryId])
  @@map("products")
}

model Supplier {
  id           String   @id @db.VarChar(26)
  tenantId     String   @map("tenant_id") @db.VarChar(26)
  name         String   @db.VarChar(200)
  email        String?  @db.VarChar(320)
  phone        String?  @db.VarChar(32)
  address      String?  @db.VarChar(300)
  taxId        String?  @map("tax_id") @db.VarChar(32)
  paymentTerms String?  @map("payment_terms") @db.VarChar(64)
  notes        String?  @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  purchaseOrders   PurchaseOrder[]
  purchaseReceipts PurchaseReceipt[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, isActive, id])
  @@map("suppliers")
}

model PurchaseOrder {
  id                    String             @id @db.VarChar(26)
  tenantId              String             @map("tenant_id") @db.VarChar(26)
  branchId              String             @map("branch_id") @db.VarChar(26)
  supplierId            String             @map("supplier_id") @db.VarChar(26)
  number                String             @db.VarChar(32)
  status                PurchaseOrderStatus @default(DRAFT)
  expectedAt            DateTime?          @map("expected_at")
  notes                 String?            @db.Text
  createdByMembershipId String?            @map("created_by_membership_id") @db.VarChar(26)
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdByMembership Membership? @relation("PurchaseOrderCreatedByMembership", fields: [createdByMembershipId], references: [id], onDelete: SetNull)

  items    PurchaseOrderItem[]
  receipts PurchaseReceipt[]

  @@unique([tenantId, number])
  @@index([tenantId, createdAt])
  @@index([tenantId, branchId, status, createdAt])
  @@index([tenantId, supplierId, status, createdAt])
  @@index([tenantId, branchId, createdByMembershipId, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String   @id @db.VarChar(26)
  tenantId        String   @map("tenant_id") @db.VarChar(26)
  purchaseOrderId String   @map("purchase_order_id") @db.VarChar(26)
  productId       String?  @map("product_id") @db.VarChar(26)
  nameSnapshot    String   @map("name_snapshot") @db.VarChar(200)
  codeSnapshot    String?  @map("code_snapshot") @db.VarChar(64)
  quantityOrdered Int      @map("quantity_ordered")
  receivedQty     Int      @default(0) @map("received_qty")
  agreedUnitCost  Decimal  @map("agreed_unit_cost") @db.Decimal(12, 2)
  lineTotal       Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  receiptItems PurchaseReceiptItem[]

  @@index([tenantId, purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model PurchaseReceipt {
  id                    String               @id @db.VarChar(26)
  tenantId              String               @map("tenant_id") @db.VarChar(26)
  branchId              String               @map("branch_id") @db.VarChar(26)
  supplierId            String               @map("supplier_id") @db.VarChar(26)
  purchaseOrderId       String               @map("purchase_order_id") @db.VarChar(26)
  number                String               @db.VarChar(32)
  status                PurchaseReceiptStatus @default(POSTED)
  receivedAt            DateTime             @map("received_at")
  notes                 String?              @db.Text
  payableId             String?              @map("payable_id") @db.VarChar(26)
  createdByMembershipId String?              @map("created_by_membership_id") @db.VarChar(26)
  createdAt             DateTime             @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdByMembership Membership? @relation("PurchaseReceiptCreatedByMembership", fields: [createdByMembershipId], references: [id], onDelete: SetNull)

  items PurchaseReceiptItem[]

  @@unique([tenantId, number])
  @@index([tenantId, receivedAt])
  @@index([tenantId, branchId, receivedAt])
  @@index([tenantId, supplierId, receivedAt])
  @@index([tenantId, purchaseOrderId, receivedAt])
  @@map("purchase_receipts")
}

model PurchaseReceiptItem {
  id                String   @id @db.VarChar(26)
  tenantId          String   @map("tenant_id") @db.VarChar(26)
  purchaseReceiptId String   @map("purchase_receipt_id") @db.VarChar(26)
  purchaseOrderItemId String @map("purchase_order_item_id") @db.VarChar(26)
  productId         String?  @map("product_id") @db.VarChar(26)
  nameSnapshot      String   @map("name_snapshot") @db.VarChar(200)
  codeSnapshot      String?  @map("code_snapshot") @db.VarChar(64)
  quantityReceived  Int      @map("quantity_received")
  actualUnitCost    Decimal  @map("actual_unit_cost") @db.Decimal(12, 2)
  lineTotal         Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseReceipt PurchaseReceipt @relation(fields: [purchaseReceiptId], references: [id], onDelete: Cascade)
  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, purchaseReceiptId])
  @@index([tenantId, purchaseOrderItemId])
  @@index([productId])
  @@map("purchase_receipt_items")
}

model Category {
  id        String   @id @db.VarChar(26)
  tenantId  String   @map("tenant_id") @db.VarChar(26)
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant                      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products                    Product[]
  productAttributeDefinitions ProductAttributeDefinition[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

model ProductAttributeDefinition {
  id               String               @id @db.VarChar(26)
  tenantId         String               @map("tenant_id") @db.VarChar(26)
  categoryId       String               @map("category_id") @db.VarChar(26)
  key              String               @db.VarChar(64)
  label            String               @db.VarChar(120)
  type             ProductAttributeType
  options          Json?                @db.JsonB
  unit             String?              @db.VarChar(24)
  isRequired       Boolean              @default(false) @map("is_required")
  isVisibleInTable Boolean              @default(false) @map("is_visible_in_table")
  sortOrder        Int                  @default(0) @map("sort_order")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([tenantId, categoryId, key])
  @@index([tenantId, categoryId])
  @@map("product_attribute_definitions")
}

model BranchInventory {
  id          String   @id @db.VarChar(26)
  tenantId    String   @map("tenant_id") @db.VarChar(26)
  branchId    String   @map("branch_id") @db.VarChar(26)
  productId   String   @map("product_id") @db.VarChar(26)
  price       Decimal? @db.Decimal(12, 2)
  cost        Decimal? @db.Decimal(12, 2)
  stockOnHand Int      @default(0) @map("stock_on_hand")
  minStock    Int      @default(0) @map("min_stock")
  maxStock    Int?     @map("max_stock")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, productId])
  @@index([tenantId, branchId])
  @@index([tenantId, productId])
  @@index([tenantId, branchId, stockOnHand])
  @@map("branch_inventories")
}

model Customer {
  id           String               @id @db.VarChar(26)
  tenantId     String               @map("tenant_id") @db.VarChar(26)
  // code is optional: @@unique allows multiple NULLs in Postgres
  code         String?              @db.VarChar(64)
  type         CustomerType         @default(RETAIL)
  taxId        String?              @map("tax_id") @db.VarChar(32)
  taxIdType    CustomerTaxIdType?   @map("tax_id_type")
  vatCondition CustomerVatCondition? @map("vat_condition")
  name         String               @db.VarChar(200)
  email        String?              @db.VarChar(320)
  phone        String?              @db.VarChar(32)
  address      String?              @db.VarChar(300)
  notes        String?              @db.Text
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders   Order[]
  invoices Invoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, taxId])
  @@index([tenantId, isActive, id])
  @@map("customers")
}

model Order {
  id            String      @id @db.VarChar(26)
  tenantId      String      @map("tenant_id") @db.VarChar(26)
  branchId      String      @map("branch_id") @db.VarChar(26)
  number        String      @db.VarChar(32)
  status        OrderStatus @default(DRAFT)
  customerId    String?     @map("customer_id") @db.VarChar(26)
  createdByMembershipId String? @map("created_by_membership_id") @db.VarChar(26)
  subtotal      Decimal     @default(0) @db.Decimal(12, 2)
  discountTotal Decimal     @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal      Decimal     @default(0) @map("tax_total") @db.Decimal(12, 2)
  total         Decimal     @default(0) @db.Decimal(12, 2)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdByMembership Membership? @relation("OrderCreatedByMembership", fields: [createdByMembershipId], references: [id], onDelete: SetNull)

  items    OrderItem[]
  invoices Invoice[]
  stockMovements StockMovement[] @relation("StockMovementOrder")

  @@unique([tenantId, number])
  @@index([tenantId, createdAt])
  @@index([tenantId, branchId, createdAt])
  @@index([tenantId, branchId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, branchId, createdByMembershipId, status])
  @@map("orders")
}

model OrderItem {
  id           String   @id @db.VarChar(26)
  tenantId     String   @map("tenant_id") @db.VarChar(26)
  orderId      String   @map("order_id") @db.VarChar(26)
  productId    String?  @map("product_id") @db.VarChar(26)
  nameSnapshot String   @map("name_snapshot") @db.VarChar(200)
  codeSnapshot String?  @map("code_snapshot") @db.VarChar(64)
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal    Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, orderId])
  @@index([productId])
  @@map("order_items")
}

model Invoice {
  id         String        @id @db.VarChar(26)
  tenantId   String        @map("tenant_id") @db.VarChar(26)
  branchId   String        @map("branch_id") @db.VarChar(26)
  orderId    String?       @map("order_id") @db.VarChar(26)
  customerId String?       @map("customer_id") @db.VarChar(26)
  number     String        @db.VarChar(32)
  displayNumber String?     @map("display_number") @db.VarChar(64)
  mode       InvoiceMode?   @map("mode")
  docType    InvoiceDocType? @map("doc_type")
  pointOfSale Int?          @map("point_of_sale")
  fiscalNumber Int?         @map("fiscal_number")
  status     InvoiceStatus @default(DRAFT)
  issuedAt   DateTime?     @map("issued_at")
  dueAt      DateTime?     @map("due_at")
  notes      String?       @db.Text
  customerNameSnapshot  String? @map("customer_name_snapshot") @db.VarChar(200)
  customerTaxIdSnapshot String? @map("customer_tax_id_snapshot") @db.VarChar(32)
  customerTaxIdTypeSnapshot CustomerTaxIdType? @map("customer_tax_id_type_snapshot")
  customerVatConditionSnapshot CustomerVatCondition? @map("customer_vat_condition_snapshot")
  customerAddressSnapshot String? @map("customer_address_snapshot") @db.VarChar(300)
  subtotal   Decimal       @default(0) @db.Decimal(12, 2)
  netSubtotal Decimal      @default(0) @map("net_subtotal") @db.Decimal(12, 2)
  taxTotal   Decimal       @default(0) @map("tax_total") @db.Decimal(12, 2)
  total      Decimal       @default(0) @db.Decimal(12, 2)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  lines    InvoiceLine[]
  fiscal   InvoiceFiscal?
  payments Payment[]

  @@unique([tenantId, number])
  @@index([tenantId, createdAt])
  @@index([tenantId, branchId, status])
  @@index([tenantId, customerId])
  @@map("invoices")
}

model InvoiceLine {
  id          String   @id @db.VarChar(26)
  tenantId    String   @map("tenant_id") @db.VarChar(26)
  invoiceId   String   @map("invoice_id") @db.VarChar(26)
  productId   String?  @map("product_id") @db.VarChar(26)
  productCodeSnapshot String? @map("product_code_snapshot") @db.VarChar(64)
  description String   @db.VarChar(500)
  quantity    Int      @default(1)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal   Decimal  @map("line_total") @db.Decimal(12, 2)
  vatRate     Decimal  @default(0.21) @map("vat_rate") @db.Decimal(6, 4)
  netUnitPrice Decimal @default(0) @map("net_unit_price") @db.Decimal(12, 2)
  netLineTotal Decimal @default(0) @map("net_line_total") @db.Decimal(12, 2)
  vatAmount   Decimal  @default(0) @map("vat_amount") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, invoiceId])
  @@index([productId])
  @@map("invoice_lines")
}

model InvoiceFiscal {
  invoiceId String @id @map("invoice_id") @db.VarChar(26)
  tenantId  String @map("tenant_id") @db.VarChar(26)
  provider  InvoiceFiscalProvider
  status    InvoiceFiscalStatus @default(PENDING)
  cae       String? @db.VarChar(32)
  caeExpiresAt DateTime? @map("cae_expires_at")
  authorizedAt DateTime? @map("authorized_at")
  qrPayload  String? @map("qr_payload") @db.Text
  requestJson  Json? @map("request_json") @db.JsonB
  responseJson Json? @map("response_json") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("invoice_fiscals")
}

model InvoiceSequence {
  id        String      @id @db.VarChar(26)
  tenantId  String      @map("tenant_id") @db.VarChar(26)
  branchId  String      @map("branch_id") @db.VarChar(26)
  mode      InvoiceMode
  docType   InvoiceDocType
  nextNumber Int        @map("next_number")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, branchId, mode, docType])
  @@index([tenantId, branchId])
  @@map("invoice_sequences")
}

model TenantBillingProfile {
  id        String   @id @db.VarChar(26)
  tenantId  String   @unique @map("tenant_id") @db.VarChar(26)
  legalName String   @map("legal_name") @db.VarChar(200)
  taxId     String   @map("tax_id") @db.VarChar(32)
  vatCondition CustomerVatCondition? @map("vat_condition")
  address   String?  @db.VarChar(300)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_billing_profiles")
}

model BranchFiscalSettings {
  id        String   @id @db.VarChar(26)
  tenantId  String   @map("tenant_id") @db.VarChar(26)
  branchId  String   @unique @map("branch_id") @db.VarChar(26)
  pointOfSale Int    @map("point_of_sale")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId])
  @@map("branch_fiscal_settings")
}

model Payment {
  id        String        @id @db.VarChar(26)
  tenantId  String        @map("tenant_id") @db.VarChar(26)
  branchId  String        @map("branch_id") @db.VarChar(26)
  invoiceId String        @map("invoice_id") @db.VarChar(26)
  status    PaymentStatus @default(PENDING)
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  paidAt    DateTime?     @map("paid_at")
  reference String?       @db.VarChar(200)
  notes     String?       @db.Text
  createdAt DateTime      @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
  @@index([tenantId, branchId, paidAt])
  @@map("payments")
}

model StockMovement {
  id             String            @id @db.VarChar(26)
  tenantId       String            @map("tenant_id") @db.VarChar(26)
  branchId       String            @map("branch_id") @db.VarChar(26)
  productId      String            @map("product_id") @db.VarChar(26)
  type           StockMovementType
  quantity       Int
  quantityBefore Int               @map("quantity_before")
  quantityAfter  Int               @map("quantity_after")
  orderId        String?           @map("order_id") @db.VarChar(26)
  referenceId    String?           @map("reference_id") @db.VarChar(26)
  referenceType  String?           @map("reference_type") @db.VarChar(32)
  note           String?           @db.VarChar(500)
  createdBy      String?           @map("created_by") @db.VarChar(26)
  createdAt      DateTime          @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order?  @relation("StockMovementOrder", fields: [orderId], references: [id], onDelete: SetNull)
  createdByUser User? @relation("StockMovementCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, createdAt])
  @@index([tenantId, productId, createdAt])
  @@index([tenantId, referenceId])
  @@index([tenantId, branchId, productId])
  @@map("stock_movements")
}
