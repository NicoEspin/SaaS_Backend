NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# CORS
# Comma-separated list of allowed origins (no trailing slash)
# Example: http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000

# Prisma / Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_saas?schema=public

# Auth
# Use a long random value (>= 32 chars)
JWT_ACCESS_SECRET=replace_me_with_a_long_random_secret
JWT_ACCESS_TTL=15m

# Optional (when you add refresh tokens)
# JWT_REFRESH_SECRET=replace_me_with_a_long_random_secret
# JWT_REFRESH_TTL=30d
