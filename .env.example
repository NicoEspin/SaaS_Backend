NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# CORS
# Comma-separated list of allowed origins (no trailing slash)
# Example: http://localhost:3000,https://app.example.com
CORS_ORIGINS=http://localhost:3000

# Prisma / Postgres
# If you run Postgres via `docker compose`, it maps container 5432 -> host 5433.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/stock_saas?schema=public

# Auth
# Use a long random value (>= 32 chars)
JWT_ACCESS_SECRET=replace_me_with_a_long_random_secret
JWT_ACCESS_TTL=15m

# Refresh tokens
JWT_REFRESH_TTL=30d

# Cookies (recommended for app.<domain> + api.<domain>)
# In production set COOKIE_DOMAIN=.miempresa.com
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
COOKIE_ACCESS_NAME=accessToken
COOKIE_REFRESH_NAME=refreshToken
